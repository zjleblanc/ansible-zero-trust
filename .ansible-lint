---
profile: production

exclude_paths:
  - .ansible/
  - .venv/
  - .git/
  - "**/secrets.yml"
  - "**/*secrets*.yml"

skip_list:
  - yaml[line-length]

warn_list:
  - no-changed-when
  - command-instead-of-module

enable_list:
  - fqcn
  - no-free-form
  - name[casing]
  - name[template]

use_default_rules: true

offline: true

kinds:
  - playbook: "playbooks/pb_*.yml"
  - tasks: "collections/ansible_collections/demo/zero_trust/roles/*/tasks/**/*.yml"
  - vars: "playbooks/vars/**/*.yml"
