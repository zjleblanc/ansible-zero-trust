---
profile: production

exclude_paths:
  - .ansible/
  - .venv/
  - collections/
  - .git/

skip_list:
  - yaml[line-length]

warn_list:
  - no-changed-when
  - command-instead-of-module

enable_list:
  - fqcn
  - no-free-form
  - name[casing]
  - name[template]

use_default_rules: true

offline: false

kinds:
  - playbook: "playbooks/pb_*.yml"
  - tasks: "playbooks/tasks/**/*.yml"
  - vars: "playbooks/vars/**/*.yml"
